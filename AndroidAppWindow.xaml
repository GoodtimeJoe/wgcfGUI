<ui:FluentWindow x:Class="WgcfGUI.AndroidAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Android App Exclusion Configuration" Height="600" Width="800"
        WindowStartupLocation="CenterOwner" 
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Android App Exclusion Configuration" Grid.Row="0" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="20,0,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Select Android Apps to Exclude" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock Text="Checked apps will bypass the Warp tunnel." Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ui:TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Grid.Column="0" Margin="0,0,10,0" PlaceholderText="Search apps..." Icon="Search24" ClearButtonEnabled="True"/>
                    
                    <ComboBox x:Name="CategoryCombo" Grid.Column="1" Margin="0,0,15,0" SelectionChanged="CategoryCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="All Categories"/>
                        <ComboBoxItem Content="Streaming"/>
                        <ComboBoxItem Content="Music"/>
                        <ComboBoxItem Content="Gaming"/>
                        <ComboBoxItem Content="Banking"/>
                        <ComboBoxItem Content="Social"/>
                        <ComboBoxItem Content="Utility / Downloads"/>
                        <ComboBoxItem Content="Browsers"/>
                        <ComboBoxItem Content="System (Android / Fire TV)"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Grid.Column="2">
                        <ui:Button Content="Select All Filtered" Click="SelectAll_Click" Margin="0,0,10,0"/>
                        <ui:Button Content="Deselect All Filtered" Click="DeselectAll_Click" Margin="0,0,10,0"/>
                        <ui:Button Content="Backup Selection" Click="ExportList_Click" Icon="ArrowExport24" Margin="0,0,10,0"/>
                        <ui:Button Content="Import Selection" Click="ImportList_Click" Icon="ArrowImport24"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <ui:ListView x:Name="AppListView" Grid.Row="1" Margin="0,0,0,15" GridViewColumnHeader.Click="GridViewColumnHeaderClickedHandler" MouseDoubleClick="AppListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="App Name" Width="200" DisplayMemberBinding="{Binding AppName}"/>
                        <GridViewColumn Header="Category" Width="120" DisplayMemberBinding="{Binding Category}"/>
                        <GridViewColumn Header="Package Name" Width="350" DisplayMemberBinding="{Binding PackageName}"/>
                    </GridView>
                </ListView.View>
            </ui:ListView>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Preview ExcludedApplications=" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ui:TextBox x:Name="PreviewTextBox" Height="60" TextWrapping="Wrap" IsReadOnly="True" Margin="0,0,0,5"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" Padding="20,15" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Click="Cancel_Click" Width="100" Margin="0,0,10,0"/>
                <ui:Button Content="Confirm Setup" Click="Confirm_Click" Width="140" Appearance="Primary"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
